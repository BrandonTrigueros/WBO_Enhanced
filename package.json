{
  "name": "wbo-enhanced",
  "description": "Enhanced collaborative whiteboard with A4 notebooks, shape recognition, and export",
  "version": "1.22.1",
  "keywords": [
    "collaborative",
    "whiteboard"
  ],
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@resvg/resvg-js": "^2.6.0",
    "accept-language-parser": "^1.5.0",
    "archiver": "^7.0.0",
    "async-mutex": "^0.5.0",
    "handlebars": "^4.7.7",
    "jsonwebtoken": "^9.0.0",
    "pdfkit": "^0.15.0",
    "polyfill-library": "^4.8.0",
    "serve-static": "^2.2.0",
    "socket.io": "^4",
    "socket.io-client": "^4",
    "statsd-client": "^0.4.7"
  },
  "scripts": {
    "start": "node ./server/server.js",
    "test": "node --test tests/unit/ && node --test tests/api/",
    "test:unit": "node --test tests/unit/",
    "test:api": "node --test tests/api/",
    "test:e2e": "nightwatch tests/e2e && nightwatch tests/e2e --env jwt",
    "test:all": "npm run test && npm run test:e2e",
    "prettier": "prettier . --write",
    "prettier-check": "prettier . --check"
  },
  "main": "./server/server.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/BrandonTrigueros/WBO_Enhanced.git"
  },
  "devDependencies": {
    "geckodriver": "^4.2.1",
    "nightwatch": "^3.2.1",
    "prettier": "^3.1.0"
  }
}
